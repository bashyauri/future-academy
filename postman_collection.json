              "host": ["{{baseUrl}}"],
              "path": ["mock", "groups", ":batchNumber", "download"],
              "query": [
                {
                  "key": "subject_id",
                  "value": "1",
                  "description": "Subject ID (required)"
                },
                {
                  "key": "exam_type_id",
                  "value": "1",
                  "description": "Exam type ID (required)"
                }
              ],
              "variable": [
                {
                  "key": "batchNumber",
                  "value": "1",
                  "description": "Batch number"
                }
              ]
            },
            "description": "Download questions for a specific mock group"
          },
          "response": []
        },
        {
          "name": "Initialize Mock Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject_ids\": [1, 2, 3, 4],\n  \"exam_type_id\": 1,\n  \"duration_minutes\": 120\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mock/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["mock", "sessions"]
            },
            "description": "Initialize a multi-subject mock session"
          },
          "response": []
        }
      ]
    },
